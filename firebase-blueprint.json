{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Represents a user in the system (client or writer/admin).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["client", "admin", "writer"] },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents an academic writing order.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "writerId": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "serviceType": { "type": "string" },
        "instructions": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "revision", "completed", "cancelled"] },
        "deadline": { "type": "string", "format": "date-time" },
        "pageCount": { "type": "number" },
        "hours": { "type": "number" },
        "totalPrice": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid", "refunded"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "title", "status", "deadline", "totalPrice", "paymentStatus"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message within an order.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "fileName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification for a user.",
      "type": "object",
      "properties": {
        "recipientId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "orderId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["recipientId", "title", "message", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Orders collection."
    },
    "/orders/{orderId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages for a specific order."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications."
    }
  }
}
