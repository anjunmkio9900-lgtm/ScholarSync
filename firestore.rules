rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check: Requires a document in 'admins' collection
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); 
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Entity Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['client', 'writer', 'admin'] &&
             (data.get('displayName', '') is string) &&
             (data.get('photoURL', '') is string);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['clientId', 'title', 'status', 'deadline', 'totalPrice', 'paymentStatus']) &&
             data.clientId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.status in ['pending', 'in-progress', 'revision', 'completed', 'cancelled'] &&
             data.deadline is timestamp &&
             data.totalPrice is number &&
             data.paymentStatus in ['unpaid', 'paid', 'refunded'];
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'createdAt']) &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() <= 5000 &&
             data.createdAt == request.time;
    }

    // --- Match Blocks ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role == existing().role; // Cannot change own role
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (existing().clientId == request.auth.uid || existing().writerId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.writerId == request.auth.uid || isAdmin());
      
      allow create: if isVerified() && isValidOrder(incoming());
      
      allow update: if isSignedIn() && (
        // Client can update instructions or cancel if pending
        (existing().clientId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['instructions', 'status', 'updatedAt']) &&
         (existing().status == 'pending' || incoming().status == 'cancelled')) ||
        
        // Writer (assigned) can update status to in-progress/completed
        (existing().writerId == request.auth.uid &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'completedAt'])) ||

        isAdmin()
      );
    }

    match /orders/{orderId}/messages/{messageId} {
      function canAccessOrder(oId) {
        let order = get(/databases/$(database)/documents/orders/$(oId)).data;
        return order.clientId == request.auth.uid || order.writerId == request.auth.uid || isAdmin();
      }

      allow read: if isSignedIn() && canAccessOrder(orderId);
      allow create: if isVerified() && canAccessOrder(orderId) && isValidMessage(incoming());
    }

    match /notifications/{notifId} {
      allow get, update: if isSignedIn() && existing().recipientId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      // System writes notifications via Admin SDK (usually)
    }

    // Required for initial connection test as per guidelines
    match /test/connection {
      allow read: if isSignedIn();
    }
  }
}
